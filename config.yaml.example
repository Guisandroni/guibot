# ──────────────────────────────────────────────
# Configuração do GuiBot para Kick
# ──────────────────────────────────────────────
# Copie para config.yaml e preencha.

kick:
  # Slug do canal (nome na URL da Kick)
  channel: "seu_canal"
  mode: websocket  # websocket | webhook | hybrid
  chat_poster_type: user  # user | bot

agent:
  enabled: true
  cooldown_seconds: 20
  trigger: "!ask"

  # Identidade do bot
  identity:
    display_name: "nome_do_bot"
    purpose: "Interagir com o chat e responder dúvidas sobre o jogo League of Legends"
    creator_note: "Configurado pelo streamer / dono do canal."

  # Informações do streamer/canal (injetado no prompt da LLM)
  streamer:
    name: "caiodurodo"       # Nome/nick do streamer
    elo: "Diamond"            # Elo atual
    role: "mid"               # Rota principal
    mains: "Ahri, Sylas"      # Champs que mais joga
    schedule: ""              # Opcional: horário de stream

  # Modelo OpenCode Go (ou OpenAI)
  model: "glm-5.1"
  max_tokens: 256
  max_response_chars: 280
  temperature: 0.8
  top_p: 0.9

  # Moderação via LLM (opcional)
  moderation:
    enabled: false
    # system_append: "Regras extras do canal..."

bot:
  prefix: "!"
  commands:
    schedule:
      response: "Horários: seg a sex às 20h!"
      cooldown: 30
    redes:
      response: "Redes sociais: https://linktr.ee/seucanal"
      cooldown: 30

  # Moderação automática (timeout/deletar mensagens)
  moderation:
    enabled: true
    timeout_duration: 300
    links_allowed: false
    link_whitelist:
      - "kick.com"
      - "youtube.com"
    blocked_words: []
    caps_warning_enabled: true
    caps_threshold_percent: 85
    caps_min_length: 12
    spam_window_seconds: 30
    spam_max_identical: 3
    repetition_enabled: false

  # Mensagens temporizadas (opcional)
  timed_messages:
    - interval: 600
      messages:
        - "Solta um !redes aí pra seguir o streamer"
        - "Não esquece de deixar o follow!"

    - interval: 1200
      message: "Manda um !schedule pra ver os horários"

  # Comment spam (mensagens automáticas do chat, lidas de arquivos .txt)
  comment_spam:
    enabled: false
    directory: "comments"
    interval: 60
    min_chars: 10
    max_chars: 200
    prompt_samples: 12

webhook:
  host: "0.0.0.0"
  port: 8420
  path: "/webhook"
