# Copia para `.env` nesta pasta (`v2/guibot`). O `bot.py` carrega sempre este `.env` junto ao ficheiro.

KICK_CLIENT_ID=your_kick_client_id
KICK_CLIENT_SECRET=your_kick_client_secret

# Canal do bot (slug Kick). Sobrescreve kick.channel em config.yaml se definido.
# Post /public/v1/chat com poster_type=user: a conta OAuth em ~/.kickforge/tokens.json tem de poder
# enviar mensagens NESSE canal (mesmo broadcaster_id). Se outro slug funcionar e este der 404, faz
# kickforge auth com a conta Kick correcta ou usa KICK_CHAT_POSTER_TYPE=bot se a app for bot-only.
# IDs fixos só se corresponderem ao MESMO slug; ao mudar canal deixa-os comentados e corre:
#   cd /path/to/guibot/v2/guibot && kickforge auth --channel <slug>
# ou: python scripts/kickforge_auth.py --channel <slug>
# para atualizar ~/.kickforge/tokens.json (chatroom + refresh token alinhados ao slug).
KICK_CHANNEL=caiodurodo

# Envio no chat Kick (POST /public/v1/chat): user | bot
# user = mensagem no canal com broadcaster_user_id (normal). bot = conta bot Kick (API ignora destino).
# Se tiveres 404 com user após trocar credenciais, tenta bot ou reautentica (abaixo).
# KICK_CHAT_POSTER_TYPE=user

# Multi-canal (vírgulas; só com KICK_MODE=websocket):
# KICK_CHANNELS=teu_canal,outro_streamer

# Moderação automática (timeouts / apagar mensagem): CSV de slugs onde a API aplica regras.
# Por defeito: primeiro canal em KICK_CHANNELS / config. Ver bot.moderation em config.yaml.
# KICK_MODERATION_CHANNELS=teu_canal

# IDs fixos — só preenche se corresponderem ao MESMO slug que KICK_CHANNEL (API Kick).
# Valores de outro canal ou cache antigo fazem o Pusher ouvir a sala errada e o POST
# /public/v1/chat pode devolver 404. Ao mudar de canal: remove estes dois e corre
# `kickforge auth --channel <slug>` para atualizar ~/.kickforge/tokens.json.
# KICK_CHATROOM_ID=
# KICK_BROADCASTER_ID=

# Obrigatório após mudar KICK_CLIENT_ID ou KICK_CLIENT_SECRET (token user desactualizado → 404):
#   cd /path/to/guibot/v2/guibot && kickforge auth --channel <slug>
# Se `kickforge auth` disser que faltam KICK_CLIENT_* mas o .env existe: pip install python-dotenv
# no mesmo Python, ou usa: python scripts/kickforge_auth.py --channel <slug>
# No portal Kick Developer confirma OAuth com scope chat:write para o token de utilizador.

KICK_MODE=websocket
# No chat: usa o agent.trigger (ex. !ask em config.yaml) ou menção a este username — não basta texto livre.
KICK_BOT_USERNAME=username_do_bot

# AI — escolhe UM provider (prioridade se várias chaves estiverem definidas: NVIDIA > OpenCode > OpenAI).
#
# NVIDIA NIM / Build (OpenAI-compatible): https://build.nvidia.com/
NVIDIA_API_KEY=sua_chave_nvidia
# Opcional; por defeito no código: https://integrate.api.nvidia.com/v1
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# OpenCode tier Go (OpenAI-compatible POST .../chat/completions).
# Comenta ou remove OPENCODE_* se usares só NVIDIA (ou define só uma chave).
OPENCODE_API_KEY=sua_chave_opencode
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
# agent.model em config.yaml: IDs NVIDIA no catálogo Build, ou IDs Go para OpenCode.

# Fallback opcional (OpenAI ou outro compatível).
# OPENAI_API_KEY=api_key_do_openai
# OPENAI_BASE_URL=

# Tavily — pesquisa web para o agente LLM (tool calling). https://tavily.com
# TAVILY_API_KEY=

# Riot: RIOT_TRIGGER_MODE=prefix|word (sobrepõe bot.riot_rank.trigger_mode). word = comando sem ! (ex.: elo).
# RIOT_WORD_POSITION=start|anywhere (sobrepõe bot.riot_rank.word_position). anywhere = palavra comando em qualquer posição na frase.
# https://developer.riotgames.com/ — header X-Riot-Token; chaves dev expiram ~24h (renovar no portal).
# RIOT_API_KEY=
# RIOT_DEFAULT_RIOT=BinBin宝贝#CN1
# RIOT_DEFAULT_PLATFORM=br1

# Landing (painel na mesma máquina): POST /api/* usa Bearer == este valor.
# LANDING_API_SECRET=
